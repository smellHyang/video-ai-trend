GITLAB_WEBHOOK_SECRET=your-webhook-secret
GITLAB_BASE_URL=https://git.cj.net
GITLAB_PRIVATE_TOKEN=glpat-xxxxxxxx
# SSL 문제 시만 (보안 주의)
# GITLAB_SSL_VERIFY=0

# MR 열기/업데이트에도 diff 조회 (디버그)
# GITLAB_FETCH_ON_MR_OPEN=1

# ---- AI 요약 (OpenAI 호환 API) ----
# AI_ENABLED=1
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# AI_MAX_INPUT_CHARS=100000

# ---- Confluence (둘 다 Atlassian이면 ATLASSIAN_* 만 써도 됨) ----
# CONFLUENCE_ENABLED=1
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# CONFLUENCE_SPACE_KEY=DEV
# CONFLUENCE_PARENT_PAGE_ID=
# ATLASSIAN_EMAIL=you@company.com
# ATLASSIAN_API_TOKEN=atlassian-api-token

# ---- Jira ----
# JIRA_ENABLED=1
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_PROJECT_KEY=DEV
# JIRA_ISSUE_TYPE=Task
# (위 ATLASSIAN_EMAIL / ATLASSIAN_API_TOKEN 재사용)

PORT=8765
HOST=0.0.0.0
